@model List<planificacion.Web.Controllers.ProjectItemViewModel>
@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewData["Title"] = "Proyectos";
    var projectIcons = (ViewData["ProjectIcons"] as string[]) ?? Array.Empty<string>();
    var defaultIcon = "bi bi-folder-fill";
}

<div class="dashboard-welcome d-flex flex-wrap align-items-center justify-content-between gap-3">
    <div>
        <h1 class="dashboard-welcome-title">Proyectos</h1>
        <p class="dashboard-welcome-subtitle text-muted mb-0">Gestiona tus proyectos y accede a sus tareas.</p>
    </div>
    <button type="button" class="btn btn-primary dashboard-btn-new-task" data-bs-toggle="modal" data-bs-target="#modalNewProject" id="btnNewProject">
        <i class="fas fa-plus"></i> Nuevo proyecto
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="projects-section">
    <div class="settings-card">
        <h2 class="settings-card-title"><i class="fas fa-folder"></i> Listado de proyectos</h2>
        <p class="settings-card-desc">Todos los proyectos en los que participas. Crea uno nuevo para organizar tareas.</p>

        @if (Model != null && Model.Count > 0)
        {
            <div class="projects-list">
                @foreach (var project in Model)
                {
                    <div class="project-item" data-project-id="@project.Id">
                        <div class="project-item-icon">
                            @if (!string.IsNullOrWhiteSpace(project.IconImagePath))
                            {
                                <img src="@project.IconImagePath" alt="Icono de @project.Name" class="project-item-icon-image" />
                            }
                            else
                            {
                                <i class="@(!string.IsNullOrWhiteSpace(project.IconClass) ? project.IconClass : defaultIcon)"></i>
                            }
                        </div>
                        <div class="project-item-body">
                            <h3 class="project-item-name">@project.Name</h3>
                            @if (!string.IsNullOrWhiteSpace(project.Description))
                            {
                                <p class="project-item-desc text-muted">@project.Description</p>
                            }
                            <span class="project-item-meta text-muted small">Creado @project.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="project-item-actions d-flex align-items-center gap-1">
                            <a asp-controller="Projects" asp-action="Detail" asp-route-id="@project.Id" class="dashboard-icon-btn" title="Abrir proyecto"><i class="fas fa-arrow-right"></i></a>
                            <form asp-controller="Projects" asp-action="Delete" method="post" class="d-inline project-delete-form" data-project-name="@project.Name">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@project.Id" />
                                <button type="submit" class="dashboard-icon-btn project-item-delete" title="Eliminar proyecto" aria-label="Eliminar proyecto">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="projects-empty text-center py-5">
                <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
                <p class="text-muted mb-2">Aún no tienes proyectos.</p>
                <p class="text-muted small mb-0">Haz clic en <strong>Nuevo proyecto</strong> para crear el primero.</p>
            </div>
        }
    </div>
</div>

<!-- Modal Nuevo proyecto -->
<div class="modal fade" id="modalNewProject" tabindex="-1" aria-labelledby="modalNewProjectLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content project-modal">
            <form asp-controller="Projects" asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header project-modal-header">
                    <h5 class="modal-title" id="modalNewProjectLabel"><i class="fas fa-folder-plus me-2"></i>Nuevo proyecto</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body project-modal-body">
                    <div class="mb-3">
                        <label for="Name" class="form-label project-modal-label"><i class="fas fa-tag me-1 project-modal-label-icon"></i>Nombre <span class="project-modal-required">*</span></label>
                        <input type="text" class="form-control project-modal-input" id="Name" name="Name" required maxlength="200" placeholder="Ej: Sitio web corporativo" />
                    </div>
                    <div class="mb-3">
                        <label for="Description" class="form-label project-modal-label"><i class="fas fa-align-left me-1 project-modal-label-icon"></i>Descripción</label>
                        <textarea class="form-control project-modal-input" id="Description" name="Description" rows="3" placeholder="Breve descripción del proyecto (opcional)"></textarea>
                    </div>
                    <div class="mb-2">
                        <label for="IconClass" class="form-label project-modal-label"><i class="fas fa-icons me-1 project-modal-label-icon"></i>Ícono</label>
                        <div class="project-icon-picker mb-2">
                            <div class="project-icon-preview" aria-hidden="true">
                                <i id="projectIconPreviewIcon" class="@defaultIcon"></i>
                            </div>
                            <span class="text-muted small">Selecciona un ícono para el proyecto</span>
                        </div>
                        <input type="text"
                               class="form-control project-modal-input project-icon-search mb-2"
                               id="ProjectIconSearch"
                               placeholder="Buscar icono (ej: phone, chart, heart, rocket)" />
                        <input type="hidden" id="IconClass" name="IconClass" value="@defaultIcon" />
                        <div class="mt-2">
                            <label for="IconFile" class="form-label project-modal-label"><i class="fas fa-upload me-1 project-modal-label-icon"></i>O subir icono propio</label>
                            <input type="file" class="form-control project-modal-input" id="IconFile" name="IconFile" accept=".png,.jpg,.jpeg,.webp,.svg,image/png,image/jpeg,image/webp,image/svg+xml" />
                            <div class="form-text">Formatos: PNG, JPG, JPEG, WEBP o SVG. Maximo 2 MB.</div>
                        </div>
                        <div class="project-icon-grid" role="listbox" aria-label="Selecciona un ícono">
                            @foreach (var icon in projectIcons)
                            {
                                var isSelected = icon == defaultIcon;
                                <button type="button"
                                        class="project-icon-option @(isSelected ? "is-selected" : "")"
                                        data-icon="@icon"
                                        role="option"
                                        aria-selected="@(isSelected ? "true" : "false")"
                                        title="@icon">
                                    <i class="@icon" aria-hidden="true"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer project-modal-footer">
                    <button type="button" class="btn project-modal-btn-cancel" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn project-modal-btn-submit"><i class="fas fa-check me-1"></i>Crear proyecto</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.project-delete-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
        var name = form.getAttribute('data-project-name') || 'este proyecto';
        if (!confirm('¿Eliminar el proyecto «' + name + '»? Esta acción no se puede deshacer.')) {
            e.preventDefault();
        }
    });
});

var iconInput = document.getElementById('IconClass');
var iconPreview = document.querySelector('.project-icon-preview');
var iconOptions = document.querySelectorAll('.project-icon-option');
var iconSearch = document.getElementById('ProjectIconSearch');
var iconFileInput = document.getElementById('IconFile');

if (iconInput && iconPreview && iconOptions.length > 0) {
    var setSelectedIcon = function(selectedIcon) {
        iconInput.value = selectedIcon || '@defaultIcon';
        iconPreview.innerHTML = '<i class="' + iconInput.value + '"></i>';

        iconOptions.forEach(function(option) {
            var isSelected = option.getAttribute('data-icon') === iconInput.value;
            option.classList.toggle('is-selected', isSelected);
            option.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        });
    };

    iconOptions.forEach(function(option) {
        option.addEventListener('click', function() {
            setSelectedIcon(option.getAttribute('data-icon'));
        });
    });

    if (iconSearch) {
        iconSearch.addEventListener('input', function() {
            var query = (iconSearch.value || '').toLowerCase().trim();
            iconOptions.forEach(function(option) {
                var iconClass = (option.getAttribute('data-icon') || '').toLowerCase();
                var shouldShow = !query || iconClass.indexOf(query) !== -1;
                option.style.display = shouldShow ? '' : 'none';
            });
        });
    }

    setSelectedIcon(iconInput.value);
}

if (iconFileInput && iconPreview) {
    iconFileInput.addEventListener('change', function() {
        var file = iconFileInput.files && iconFileInput.files[0];
        if (!file) {
            return;
        }

        var imageUrl = URL.createObjectURL(file);
        iconPreview.innerHTML = '<img src="' + imageUrl + '" alt="Vista previa" class="project-icon-preview-image" />';
    });
}
</script>
}
