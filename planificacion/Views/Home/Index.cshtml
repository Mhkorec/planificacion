    <script>
        (function () {
            var views = document.getElementById('dashboardViews');
            var listView = document.getElementById('dashboardViewList');
            if (!views || !listView) return;
            var tabs = views.querySelectorAll('.dashboard-view-tab[data-view]');
            var board = views.querySelector('.dashboard-view-board');
            function showView(view) {
                views.setAttribute('data-current-view', view);
                if (view === 'list') {
                    if (board) board.style.display = 'none';
                    listView.hidden = false;
                } else {
                    if (board) board.style.display = '';
                    listView.hidden = true;
                }
            }
            tabs.forEach(function (tab) {
                tab.addEventListener('click', function () {
                    var view = this.getAttribute('data-view');
                    tabs.forEach(function (t) {
                        t.classList.toggle('active', t === tab);
                        t.setAttribute('aria-pressed', t === tab ? 'true' : 'false');
                    });
                    showView(view);
                });
            });

            /* Filtros */
            var filterToggle = document.getElementById('filterToggle');
            var filterDropdown = document.getElementById('filterDropdown');
            var filterApply = document.getElementById('filterApply');
            var filterClear = document.getElementById('filterClear');
            var filterBadge = document.getElementById('filterBadge');
            if (filterToggle && filterDropdown) {
                filterToggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var open = !filterDropdown.hidden;
                    filterDropdown.hidden = !open;
                    filterToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                });
                document.addEventListener('click', function () {
                    filterDropdown.hidden = true;
                    filterToggle.setAttribute('aria-expanded', 'false');
                });
                filterDropdown.addEventListener('click', function (e) { e.stopPropagation(); });
            }
            function getActiveFilters() {
                var status = [];
                var priority = [];
                var owner = [];
                views.querySelectorAll('input[name="filterStatus"]:checked').forEach(function (c) { status.push(c.value); });
                views.querySelectorAll('input[name="filterPriority"]:checked').forEach(function (c) { priority.push(c.value); });
                views.querySelectorAll('input[name="filterOwner"]:checked').forEach(function (c) { owner.push(c.value); });
                return { status: status, priority: priority, owner: owner };
            }
            function applyFilters() {
                var f = getActiveFilters();
                var total = f.status.length + f.priority.length + f.owner.length;
                if (filterBadge) {
                    if (total === 0) {
                        filterBadge.hidden = true;
                    } else {
                        filterBadge.hidden = false;
                        filterBadge.textContent = total;
                    }
                }
                function matches(item) {
                    var s = item.getAttribute('data-status');
                    var p = item.getAttribute('data-priority');
                    var o = item.getAttribute('data-owner');
                    if (f.status.length && (!s || f.status.indexOf(s) === -1)) return false;
                    if (f.priority.length && (!p || f.priority.indexOf(p) === -1)) return false;
                    if (f.owner.length && (!o || f.owner.indexOf(o) === -1)) return false;
                    return true;
                }
                if (board) {
                    board.querySelectorAll('.dashboard-card').forEach(function (card) {
                        card.style.display = matches(card) ? '' : 'none';
                    });
                }
                listView.querySelectorAll('.dashboard-task-row').forEach(function (row) {
                    row.style.display = matches(row) ? '' : 'none';
                });
            }
            if (filterApply) filterApply.addEventListener('click', function () {
                applyFilters();
                if (filterDropdown) filterDropdown.hidden = true;
                if (filterToggle) filterToggle.setAttribute('aria-expanded', 'false');
            });
            if (filterClear) filterClear.addEventListener('click', function () {
                views.querySelectorAll('.dashboard-filter-dropdown input[type="checkbox"]').forEach(function (c) { c.checked = false; });
                applyFilters();
                if (filterDropdown) filterDropdown.hidden = true;
                if (filterToggle) filterToggle.setAttribute('aria-expanded', 'false');
            });
            views.querySelectorAll('.dashboard-filter-dropdown input[type="checkbox"]').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var f = getActiveFilters();
                    var total = f.status.length + f.priority.length + f.owner.length;
                    if (filterBadge) {
                        filterBadge.hidden = total === 0;
                        filterBadge.textContent = total;
                    }
                });
            });

            /* Modal Nueva tarea */
            var btnNewTask = document.getElementById('btnNewTask');
            var overlay = document.getElementById('modalNewTaskOverlay');
            var modal = document.getElementById('modalNewTask');
            var closeBtn = document.getElementById('modalNewTaskClose');
            var cancelBtn = document.getElementById('modalNewTaskCancel');
            var formNewTask = document.getElementById('formNewTask');

            function openNewTaskModal() {
                if (overlay) {
                    overlay.hidden = false;
                    document.body.classList.add('task-modal-open');
                    setTimeout(function () {
                        var firstInput = document.getElementById('taskName');
                        if (firstInput) firstInput.focus();
                    }, 100);
                }
            }
            function closeNewTaskModal() {
                if (overlay) {
                    overlay.hidden = true;
                    document.body.classList.remove('task-modal-open');
                }
            }

            if (btnNewTask) btnNewTask.addEventListener('click', openNewTaskModal);
            if (closeBtn) closeBtn.addEventListener('click', closeNewTaskModal);
            if (cancelBtn) cancelBtn.addEventListener('click', closeNewTaskModal);
            if (overlay) {
                overlay.addEventListener('click', function (e) {
                    if (e.target === overlay) closeNewTaskModal();
                });
            }
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && overlay && !overlay.hidden) closeNewTaskModal();
            });
            if (formNewTask) {
                formNewTask.addEventListener('submit', function (e) {
                    e.preventDefault();
                    /* Aquí puedes enviar el formulario por AJAX o redirigir */
                    closeNewTaskModal();
                    formNewTask.reset();
                });
            }
        })();
    </script>
}
else
{
    <div class="text-center">
        <h1 class="display-4">Planificacion</h1>
        <p>Proyecto base con Clean Architecture (Domain, Application, Infrastructure, Web)</p>
        <p>Basado en la estructura de SanLuisInvestiga.</p>
    </div>
}
