@{
    ViewData["Title"] = "Contacto";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="contact-container p-5">
                <h2 class="text-center mb-5">Contacto</h2>

                <div class="contact-sections">
                    <!-- Emails -->
                    <div class="contact-block mb-5">
                        <div class="section-header">
                            <i class="fas fa-envelope"></i>
                            <h4>Emails</h4>
                        </div>
                        <div class="section-content">
                            <ul class="contact-list">
                                <li>
                                    <a href="mailto:contacto@ejemplo.com" class="contact-link">
                                        <i class="fas fa-at"></i>
                                        contacto@ejemplo.com
                                    </a>
                                </li>
                                <li>
                                    <a href="mailto:info@ejemplo.com" class="contact-link">
                                        <i class="fas fa-at"></i>
                                        info@ejemplo.com
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Ubicación -->
                    <div class="contact-block mb-5">
                        <div class="section-header">
                            <i class="fas fa-map-marker-alt"></i>
                            <h4>Ubicación</h4>
                        </div>
                        <div class="section-content">
                            <div class="location-info">
                                <i class="fas fa-building"></i>
                                <p>Calle Ejemplo 123, Ciudad, Provincia. CP 5000 - País.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Teléfonos -->
                    <div class="contact-block">
                        <div class="section-header">
                            <i class="fas fa-phone-alt"></i>
                            <h4>Teléfonos</h4>
                        </div>
                        <div class="section-content">
                            <ul class="contact-list">
                                <li>
                                    <a href="tel:+5491112345678" class="contact-link">
                                        <i class="fas fa-phone"></i>
                                        +54 11 1234-5678
                                    </a>
                                </li>
                                <li>
                                    <a href="https://wa.me/5491112345678" target="_blank" rel="noopener noreferrer" class="contact-link whatsapp">
                                        <i class="fab fa-whatsapp"></i>
                                        WhatsApp: 11 1234-5678
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
