@model planificacion.Web.ViewModels.Auth.RegisterVm
@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-login-page">
    <div class="auth-login-card">
        <div class="auth-card-left">
            <div class="auth-brand">
                <img src="~/img/logo.png" alt="Logo" class="auth-logo" asp-append-version="true" />
                <h1 class="auth-app-name">Planificacion</h1>
                <p class="auth-app-subtitle">Sistema de Gestión de Tareas</p>
            </div>
            <ul class="auth-features">
                <li class="auth-feature auth-feature-blue">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Organización Inteligente
                </li>
                <li class="auth-feature auth-feature-orange">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Tableros y Proyectos
                </li>
                <li class="auth-feature auth-feature-pink">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Planificación Visual
                </li>
                <li class="auth-feature auth-feature-green">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Seguimiento en Tiempo Real
                </li>
            </ul>
        </div>
        <div class="auth-card-divider"></div>
        <div class="auth-card-right">
            <div class="auth-form-header">
                <h2 class="auth-form-title">Crear cuenta</h2>
                <p class="auth-form-subtitle">Completa tus datos para registrarte</p>
            </div>
            <form asp-action="Register" method="post" id="registerForm" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>
                <div class="auth-field">
                    <label asp-for="Nombre" class="auth-label">
                        <i class="fas fa-user auth-label-icon"></i>Nombre
                    </label>
                    <input asp-for="Nombre" class="auth-input" placeholder="Tu nombre"
                           autocomplete="given-name" required />
                    <span asp-validation-for="Nombre" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="Apellido" class="auth-label">
                        <i class="fas fa-user auth-label-icon"></i>Apellido
                    </label>
                    <input asp-for="Apellido" class="auth-input" placeholder="Tu apellido"
                           autocomplete="family-name" required />
                    <span asp-validation-for="Apellido" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="Email" class="auth-label">
                        <i class="fas fa-envelope auth-label-icon"></i>Correo Electrónico
                    </label>
                    <input asp-for="Email" class="auth-input" placeholder="tu.correo@ejemplo.com"
                           autocomplete="email" required />
                    <span asp-validation-for="Email" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="Password" class="auth-label">
                        <i class="fas fa-lock auth-label-icon"></i>Contraseña
                    </label>
                    <div class="auth-password-wrap">
                        <input asp-for="Password" class="auth-input auth-input-password"
                               placeholder="Mín. 8 caracteres, mayúscula, minúscula, número y símbolo"
                               autocomplete="new-password" id="passwordInput" required />
                        <button type="button" class="auth-toggle-password" id="togglePassword" aria-label="Mostrar contraseña">
                            <i class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                    <p class="auth-password-hint">Al menos 8 caracteres, una mayúscula, una minúscula, un número y un carácter especial (ej. @@$!%*?).</p>
                    <span asp-validation-for="Password" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="ConfirmPassword" class="auth-label">
                        <i class="fas fa-lock auth-label-icon"></i>Confirmar contraseña
                    </label>
                    <div class="auth-password-wrap">
                        <input asp-for="ConfirmPassword" class="auth-input auth-input-password"
                               placeholder="Repite tu contraseña" autocomplete="new-password" id="confirmPasswordInput" />
                        <button type="button" class="auth-toggle-password" id="toggleConfirmPassword" aria-label="Mostrar contraseña">
                            <i class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
                </div>
                <button type="submit" class="auth-btn-submit" id="registerBtn">
                    <i class="fas fa-user-plus auth-btn-icon"></i>Registrarse
                </button>
            </form>
            <p class="auth-footer-text">
                ¿Ya tienes cuenta? <a asp-controller="Auth" asp-action="Login" class="auth-link-register">Iniciar sesión</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            $('#registerForm').submit(function () {
                var btn = $('#registerBtn');
                btn.prop('disabled', true);
                btn.html('<i class="fas fa-spinner fa-spin auth-btn-icon"></i>Creando cuenta...');
            });
            $('#Nombre').focus();

            function setupToggle(inputId, toggleId) {
                $(toggleId).on('click', function () {
                    var input = $(inputId);
                    var icon = $(this).find('i');
                    if (input.attr('type') === 'password') {
                        input.attr('type', 'text');
                        icon.removeClass('fa-eye-slash').addClass('fa-eye');
                        $(this).attr('aria-label', 'Ocultar contraseña');
                    } else {
                        input.attr('type', 'password');
                        icon.removeClass('fa-eye').addClass('fa-eye-slash');
                        $(this).attr('aria-label', 'Mostrar contraseña');
                    }
                });
            }
            setupToggle('#passwordInput', '#togglePassword');
            setupToggle('#confirmPasswordInput', '#toggleConfirmPassword');
        });
    </script>
}
