@model planificacion.Web.ViewModels.Auth.LoginVm
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-login-page">
    <div class="auth-login-card">
        <div class="auth-card-left">
            <div class="auth-brand">
                <img src="~/img/logo.png" alt="Logo" class="auth-logo" asp-append-version="true" />
                <h1 class="auth-app-name">Planificacion</h1>
                <p class="auth-app-subtitle">Sistema de Gestión de Tareas</p>
            </div>
            <ul class="auth-features">
                <li class="auth-feature auth-feature-blue">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Organización Inteligente
                </li>
                <li class="auth-feature auth-feature-orange">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Tableros y Proyectos
                </li>
                <li class="auth-feature auth-feature-pink">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Planificación Visual
                </li>
                <li class="auth-feature auth-feature-green">
                    <span class="auth-feature-icon"><i class="fas fa-check"></i></span>
                    Seguimiento en Tiempo Real
                </li>
            </ul>
        </div>
        <div class="auth-card-divider"></div>
        <div class="auth-card-right">
            <div class="auth-form-header">
                <h2 class="auth-form-title">Iniciar Sesión</h2>
                <p class="auth-form-subtitle">Accede a tu cuenta</p>
            </div>
            <form asp-action="Login" method="post" id="loginForm" class="auth-form">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>
                @if (TempData["Error"] != null)
                {
                    <div class="auth-alert-error" role="alert">@TempData["Error"]</div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="auth-alert-success" role="alert">@TempData["Success"]</div>
                }
                <div class="auth-field">
                    <label asp-for="Email" class="auth-label">
                        <i class="fas fa-envelope auth-label-icon"></i>Correo Electrónico
                    </label>
                    <input asp-for="Email" class="auth-input" placeholder="tu.usuario@ejemplo.com"
                           autocomplete="email" required id="Email" />
                    <span asp-validation-for="Email" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="Password" class="auth-label">
                        <i class="fas fa-lock auth-label-icon"></i>Contraseña
                    </label>
                    <div class="auth-password-wrap">
                        <input asp-for="Password" class="auth-input auth-input-password"
                               placeholder="••••••••" autocomplete="current-password"
                               id="passwordInput" required />
                        <button type="button" class="auth-toggle-password" id="togglePassword" aria-label="Mostrar contraseña">
                            <i class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="auth-field-error"></span>
                </div>
                <div class="auth-options">
                    <label class="auth-checkbox">
                        <input asp-for="RememberMe" type="checkbox" class="auth-checkbox-input" />
                        <span class="auth-checkbox-label">Recordarme</span>
                    </label>
                    <a href="#" class="auth-link-forgot">¿Olvidaste tu contraseña?</a>
                </div>
                <button type="submit" class="auth-btn-submit" id="loginBtn">
                    <i class="fas fa-right-to-bracket auth-btn-icon"></i>Iniciar Sesión
                </button>
            </form>
            <p class="auth-footer-text">
                ¿No tienes cuenta? <a asp-controller="Auth" asp-action="Register" class="auth-link-register">Crear cuenta</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            $('#loginForm').submit(function () {
                var loginBtn = $('#loginBtn');
                loginBtn.prop('disabled', true);
                loginBtn.html('<i class="fas fa-spinner fa-spin auth-btn-icon"></i>Iniciando sesión...');
            });
            $('#Email').focus();

            $('#togglePassword').on('click', function () {
                var input = $('#passwordInput');
                var icon = $(this).find('i');
                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                    $(this).attr('aria-label', 'Ocultar contraseña');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                    $(this).attr('aria-label', 'Mostrar contraseña');
                }
            });
        });
    </script>
}
