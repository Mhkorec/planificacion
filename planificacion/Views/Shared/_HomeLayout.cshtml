<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Planificacion</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <script>
        (function () {
            function hexToRgba(hex, a) {
                if (!hex || hex.indexOf('#') !== 0) return 'rgba(45,127,249,0.2)';
                var m = hex.slice(1).match(/([a-f0-9]{2})([a-f0-9]{2})([a-f0-9]{2})/i);
                if (!m) return 'rgba(45,127,249,0.2)';
                return 'rgba(' + parseInt(m[1], 16) + ',' + parseInt(m[2], 16) + ',' + parseInt(m[3], 16) + ',' + a + ')';
            }
            try {
                var raw = localStorage.getItem('dashboardTheme');
                if (raw) {
                    var data = JSON.parse(raw);
                    if (data && data.theme) {
                        var t = data.theme;
                        var r = document.documentElement;
                        r.style.setProperty('--dash-blue', t.blue || '#2D7FF9');
                        r.style.setProperty('--dash-orange', t.orange || '#FFB020');
                        r.style.setProperty('--dash-purple', t.purple || '#7B61FF');
                        r.style.setProperty('--dash-green', t.green || '#52C41A');
                        r.style.setProperty('--dash-column-blue', hexToRgba(t.blue, 0.2));
                        r.style.setProperty('--dash-column-orange', hexToRgba(t.orange, 0.2));
                        r.style.setProperty('--dash-column-purple', hexToRgba(t.purple, 0.2));
                        r.style.setProperty('--dash-column-green', hexToRgba(t.green, 0.2));
                    }
                }
            } catch (e) {}
        })();
    </script>
</head>
<body class="dashboard-body">
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentSection = ViewData["CurrentSection"] as string ?? "";
    }
    <aside class="dashboard-sidebar">
        <div class="dashboard-sidebar-logo">
            <img src="~/img/logo.png" alt="Planificacion" class="dashboard-logo-img" asp-append-version="true" />
        </div>
        <nav class="dashboard-nav">
            <a asp-controller="Home" asp-action="Index" class="dashboard-nav-item @(controller == "Home" && currentSection != "Tasks" ? "active" : "")">
                <i class="fas fa-home dashboard-nav-icon"></i>
                <span>Home</span>
            </a>
            <a asp-controller="Home" asp-action="Index" asp-route-view="list" class="dashboard-nav-item @(currentSection == "Tasks" ? "active" : "")">
                <i class="fas fa-list-check dashboard-nav-icon"></i>
                <span>Tasks</span>
            </a>
            <a asp-controller="Projects" asp-action="Index" class="dashboard-nav-item @(controller == "Projects" ? "active" : "")">
                <i class="fas fa-folder dashboard-nav-icon"></i>
                <span>Projects</span>
            </a>
            <a href="#" class="dashboard-nav-item">
                <i class="fas fa-calendar dashboard-nav-icon"></i>
                <span>Calendar</span>
            </a>
            <a href="#" class="dashboard-nav-item">
                <i class="fas fa-users dashboard-nav-icon"></i>
                <span>Team</span>
            </a>
            <a href="#" class="dashboard-nav-item">
                <i class="fas fa-folder-open dashboard-nav-icon"></i>
                <span>Files</span>
            </a>
            <a asp-controller="Settings" asp-action="Index" class="dashboard-nav-item @(controller == "Settings" ? "active" : "")">
                <i class="fas fa-gear dashboard-nav-icon"></i>
                <span>Settings</span>
            </a>
        </nav>
    </aside>
    <div class="dashboard-main-wrap">
        <header class="dashboard-navbar">
            <div class="dashboard-search-wrap">
                <i class="fas fa-search dashboard-search-icon"></i>
                <input type="search" class="dashboard-search-input" placeholder="Buscar..." aria-label="Buscar" />
            </div>
            <div class="dashboard-navbar-actions">
                <button type="button" class="dashboard-icon-btn" title="Añadir">
                    <i class="fas fa-plus"></i>
                </button>
                <a href="#" class="dashboard-icon-btn dashboard-icon-btn-badge" title="Notificaciones">
                    <i class="fas fa-bell"></i>
                    <span class="dashboard-badge">2</span>
                </a>
                <button type="button" class="dashboard-icon-btn" title="Actividad">
                    <i class="fas fa-bolt"></i>
                </button>
                <div class="dropdown">
                    <button type="button" class="dashboard-avatar-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Cuenta">
                        <span class="dashboard-avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpperInvariant() ?? "U")</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end dashboard-dropdown">
                        <li><span class="dropdown-item-text text-muted small">@User.Identity?.Name</span></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item">Cerrar sesión</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>
        <main class="dashboard-content">
            @RenderBody()
        </main>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
